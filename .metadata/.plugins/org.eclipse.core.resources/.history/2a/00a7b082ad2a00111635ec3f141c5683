/* --- 內部函式：將語句推入佇列 --- */
static bool queue_push(const char *line, uint16_t len) { [cite: 1824]
    if (!line || len == 0 || len >= GPS_SENTENCE_MAX_LEN) return false; [cite: 1826]
    if (g_queue.count >= GPS_SENTENCE_QUEUE_SIZE) return false; [cite: 1827]

    GPS_Sentence_t *slot = &g_queue.items[g_queue.tail]; [cite: 1828]
    memset(slot, 0, sizeof(*slot)); [cite: 1829]
    memcpy(slot->sentence, line, len); [cite: 1830]
    slot->sentence[len] = '\0'; [cite: 1831]
    slot->len = len; [cite: 1832]
    slot->tick_ms = HAL_GetTick(); [cite: 1833]

    g_queue.tail = (uint8_t)((g_queue.tail + 1U) % GPS_SENTENCE_QUEUE_SIZE); [cite: 1834]
    g_queue.count++; [cite: 1834]
    return true; [cite: 1835]
}

