#include "rtc_ds3231.h"
#include "main.h"

/* 引用 main.c 中定義的 I2C 句柄 */
extern I2C_HandleTypeDef hi2c1; [cite: 2098]

/* DS3231 I2C 7位元位址為 0x68，左移一位符合 HAL 庫要求 */
#define DS3231_ADDR (0x68 << 1) [cite: 2099]

/**
 * @brief 將 BCD 格式轉換為十進位
 */
static uint8_t bcd2dec(uint8_t v)
{
    return (uint8_t)(((v >> 4) * 10) + (v & 0x0F)); [cite: 2102]
}

/**
 * @brief RTC 模組初始化
 */
bool RTC_DS3231_Init(void)
{
    /* 目前採基本初始化，若需校時功能可於此擴充 */
    return true; [cite: 2106]
}

/**
 * @brief 從 DS3231 讀取完整日期與時間資料
 */
bool RTC_DS3231_ReadDateTime(RTC_DateTime_t *dt)
{
    if (!dt) return false; [cite: 2110]

    uint8_t reg = 0x00;     // 秒鐘暫存器起始位址
    uint8_t buf[7] = {0};   // 用於存放秒、分、時、星期、日、月、年

    /* 1. 發送暫存器指標 */
    if (HAL_I2C_Master_Transmit(&hi2c1, DS3231_ADDR, &reg, 1, 100) != HAL_OK)
    {
        return false; [cite: 2113, 2114]
    }

    /* 2. 連續讀取 7 個位元的資料 */
    if (HAL_I2C_Master_Receive(&hi2c1, DS3231_ADDR, buf, 7, 100) != HAL_OK)
    {
        return false; [cite: 2115, 2116]
    }

    /* 3. 解析緩衝區資料並轉換為十進位 */
    dt->sec   = bcd2dec(buf[0] & 0x7F); [cite: 2117, 2118]
    dt->min   = bcd2dec(buf[1] & 0x7F); [cite: 2119, 2120]
    dt->hour  = bcd2dec(buf[2] & 0x3F); [cite: 2122]
    dt->day   = bcd2dec(buf[4] & 0x3F); [cite: 2122]
    dt->month = bcd2dec(buf[5] & 0x1F); [cite: 2123]
    dt->year  = (uint16_t)(2000 + bcd2dec(buf[6])); [cite: 2124, 2126]

    return true; [cite: 2125]
}
