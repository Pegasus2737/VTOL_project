#include "gps.h"
#include "main.h"
#include <string.h>

/* 外部硬體控制句柄 */
extern UART_HandleTypeDef huart2;
extern DMA_HandleTypeDef hdma_usart2_rx;

/* 內部緩衝區與變數定義 */
uint8_t  g_dma_buf[GPS_DMA_BUF_SIZE];      // DMA 直接存放區 [cite: 1819]
uint8_t  g_chunk_buf[GPS_CHUNK_BUF_SIZE];  // 單次 IDLE 接收快照區 [cite: 1819]
volatile uint16_t g_chunk_len = 0;         // 本次快照長度 [cite: 1820]
volatile uint8_t  g_chunk_ready = 0;       // 快照就緒旗標 [cite: 1820]

static char     g_acc_buf[GPS_ACC_BUF_SIZE];      // 數據累積區，用於處理斷句 [cite: 1821]
static uint16_t g_acc_len = 0;                    // 累積區當前長度 [cite: 1822]

static GPS_SentenceQueue_t g_queue;               // 已斷句的 NMEA 語句佇列 [cite: 1823]

/* --- 內部函式：將語句推入佇列 --- */
static bool queue_push(const char *line, uint16_t len) {
    if (!line || len == 0 || len >= GPS_SENTENCE_MAX_LEN) return false;
    if (g_queue.count >= GPS_SENTENCE_QUEUE_SIZE) return false;

    GPS_Sentence_t *slot = &g_queue.items[g_queue.tail];
    memset(slot, 0, sizeof(*slot));
    memcpy(slot->sentence, line, len);
    slot->sentence[len] = '\0';
    slot->len = len;
    slot->tick_ms = HAL_GetTick();

    g_queue.tail = (uint8_t)((g_queue.tail + 1U) % GPS_SENTENCE_QUEUE_SIZE);
    g_queue.count++;
    return true;
}

/* --- 初始化 GPS 模組變數 --- */
void GPS_Init(void) {
    memset(g_dma_buf, 0, sizeof(g_dma_buf));
    memset(g_chunk_buf, 0, sizeof(g_chunk_buf));
    memset(g_acc_buf, 0, sizeof(g_acc_buf));
    memset(&g_queue, 0, sizeof(g_queue));
    g_chunk_len = 0;
    g_chunk_ready = 0;
    g_acc_len = 0;
}

/* --- 啟動 DMA 接收與 IDLE 中斷 --- */
void GPS_StartReception(void) {
    // 循環 DMA 模式下：一次初始化，DMA 會自動循環，不需要重啟
    static uint8_t initialized = 0;
    if (!initialized) {
        HAL_UART_Receive_DMA(&huart2, (uint8_t*)g_dma_buf, GPS_DMA_BUF_SIZE);
        initialized = 1;
    }
    // IDLE 中斷已在 MSP 初始化中啟用，無需再次設定
}

/* --- 停止接收 --- */
void GPS_StopReception(void) {
    __HAL_UART_DISABLE_IT(&huart2, UART_IT_IDLE);
    HAL_UART_DMAStop(&huart2);
}

/* --- 中斷回呼：暫存本次 DMA 數據 (在 USART2_IRQHandler 中調用) --- */
void GPS_OnRxEvent(uint16_t size) {
    if (size == 0 || size > GPS_CHUNK_BUF_SIZE) return;
    memcpy(g_chunk_buf, g_dma_buf, size);
    g_chunk_len = size;
    g_chunk_ready = 1;
    
    // 診斷：每次調用記錄一次
    extern UART_HandleTypeDef huart1;
    static uint32_t call_count = 0;
    call_count++;
    if (call_count % 10 == 0) {  // 每 10 次調用輸出一次
        char diag[96];
        snprintf(diag, sizeof(diag), "$ONRX,calls=%lu,size=%u\r\n", call_count, size);
        HAL_UART_Transmit(&huart1, (uint8_t *)diag, strlen(diag), 100);
    }
}

/* --- 任務處理：將快照存入累積區 --- */
void GPS_ProcessRxChunk(void) {
    if (!g_chunk_ready) return;

    // 若緩衝區溢位則重置
    if ((g_acc_len + g_chunk_len) >= GPS_ACC_BUF_SIZE) {
        g_acc_len = 0;
        memset(g_acc_buf, 0, sizeof(g_acc_buf));
    }

    memcpy(&g_acc_buf[g_acc_len], g_chunk_buf, g_chunk_len);
    g_acc_len += g_chunk_len;
    g_chunk_ready = 0;
    
    // 診斷：記錄本次移動的字節數
    extern UART_HandleTypeDef huart1;
    uint16_t prev_len = g_chunk_len;
    g_chunk_len = 0;
    
    char diag[96];
    snprintf(diag, sizeof(diag), "$PROC,chunk=%u,acc_len=%u\r\n", prev_len, g_acc_len);
    HAL_UART_Transmit(&huart1, (uint8_t *)diag, strlen(diag), 100);
}

/* --- 任務處理：掃描累積區並切分語句 --- */
void GPS_SplitLinesToQueue(void) {
    uint16_t start = 0U;
    for (uint16_t i = 0; i < g_acc_len; ++i) {
        if (g_acc_buf[i] == '\n') { // 發現換行字元 [cite: 1884]
            uint16_t line_len = (uint16_t)(i - start + 1U);
            if (line_len > 2) {
                char line[GPS_SENTENCE_MAX_LEN] = {0};
                uint16_t copy_len = line_len >= GPS_SENTENCE_MAX_LEN ?
                                   (GPS_SENTENCE_MAX_LEN - 1) : line_len;

                memcpy(line, &g_acc_buf[start], copy_len);
                line[copy_len] = '\0';

                // 清除結尾的 \r 或 \n [cite: 1894]
                while (copy_len > 0 && (line[copy_len - 1] == '\r' || line[copy_len - 1] == '\n')) {
                    line[copy_len - 1] = '\0';
                    copy_len--;
                }

                // 驗證語句是否以 $ 開始 [cite: 1900]
                if (copy_len > 0 && line[0] == '$') {
                    queue_push(line, copy_len);
                }
            }
            start = i + 1;
        }
    }

    // 將處理剩餘的碎片搬移至緩衝區開頭 [cite: 1906]
    if (start > 0) {
        uint16_t remain = g_acc_len - start;
        if (remain > 0) memmove(g_acc_buf, &g_acc_buf[start], remain);
        memset(&g_acc_buf[remain], 0, GPS_ACC_BUF_SIZE - remain);
        g_acc_len = remain;
    }
}

/* --- 外部提取：從佇列取出處理好的語句 --- */
bool GPS_QueuePop(GPS_Sentence_t *out) {
    if (!out) return false;
    if (g_queue.count == 0U) return false;

    *out = g_queue.items[g_queue.head];
    g_queue.head = (uint8_t)((g_queue.head + 1U) % GPS_SENTENCE_QUEUE_SIZE);
    g_queue.count--;
    return true;
}
